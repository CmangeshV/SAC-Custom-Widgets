{
  "id": "com.custom.barchart",
  "version": "1.0.0",
  "name": "Custom Bar Chart",
  "description": "A bar chart built with custom widget",
  "newInstancePrefix": "CustomBarChart",
  "icon": "https://your-username.github.io/SAC-Custom-Widgets/barchart/icon.png",
  "webcomponents": [
    {
      "kind": "main",
      "tag": "com-custom-barchart",
      "url": "https://https://github.com/CmangeshV/SAC-Custom-Widgets/blob/main/BarchartNew.js",
      "ignoreIntegrity": true
    }
  ],
  "properties": {
    "chartData": {
      "type": "string",
      "description": "JSON string of chart data",
      "default": ""
    },
    "barColor": {
      "type": "string",
      "description": "Bar fill color",
      "default": "#4A90E2"
    }
  },
  "methods": {
    "setData": {
      "description": "Set chart data",
      "parameters": [
        { "name": "data", "type": "string" }
      ]
    }
  },
  "events": {
    "onClick": {
      "description": "Fired when a bar is clicked"
    }
  }
}
